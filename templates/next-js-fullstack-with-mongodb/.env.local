# Environment variables
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_SECRET=<your_secret_key>

# ImageKit
IMGKIT_PUBLIC_KEY=
IMGKIT_PRIVATE_KEY=
NEXT_PUBLIC_IMGKIT_URL_ENDPOINT=

# MongoDB Connection Server
NEXT_PUBLIC_MONGO_DB_SERVER=<your_mongodb_server>

# MongoDB Cluster Name
NEXT_PUBLIC_CLUSTER_ACCOUNTS=<your_mongodb_cluster_name>

# Node environment
NODE_ENV=development